generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Identity & Access Management (IAM)
// ==========================================
enum Role {
  ADMIN
  ACCOUNTANT
  CASHIER
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          Role      @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sales         Sale[]
  activityLogs  ActivityLog[]
  shifts        Shift[]
}

// ==========================================
// Inventory Management (Tanks & Fuel)
// ==========================================
model FuelType {
  id            String    @id @default(cuid())
  name          String    // e.g., "Super 98", "Diesel"
  code          String    @unique // e.g., "S98", "DSL"
  pricePerLiter Float

  tanks         Tank[]
  salesItems    SaleItem[]
  purchases     Purchase[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Tank {
  id            String    @id @default(cuid())
  name          String    // e.g., "Tank 1 - Super 98"
  capacity      Float     // Total capacity in Liters
  currentVolume Float     // Current Liters available

  fuelTypeId    String
  fuelType      FuelType  @relation(fields: [fuelTypeId], references: [id])
  pumps         Pump[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==========================================
// Pumps & Shifts Management
// ==========================================
enum PumpStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model Pump {
  id            String    @id @default(cuid())
  name          String    // e.g., "Pump 1", "Pump 2"
  status        PumpStatus @default(ACTIVE)

  tankId        String
  tank          Tank      @relation(fields: [tankId], references: [id])

  meterReading  Float     @default(0) // Lifetime total liters dispensed
  
  shifts        Shift[]
  sales         Sale[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model Shift {
  id              String      @id @default(cuid())
  status          ShiftStatus @default(OPEN)
  
  userId          String      
  user            User        @relation(fields: [userId], references: [id])

  pumpId          String
  pump            Pump        @relation(fields: [pumpId], references: [id])

  openingMeter    Float       
  closingMeter    Float?      
  
  expectedLiters  Float       @default(0) 
  actualLiters    Float?      

  sales           Sale[]

  openedAt        DateTime    @default(now())
  closedAt        DateTime?
}

// ==========================================
// Sales & Point of Sale (POS)
// ==========================================
enum PaymentMethod {
  CASH
  BANK
}

model Sale {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique // e.g., INV-20260404-A1B2C
  totalAmount   Float
  vatAmount     Float     // standard 15% ZATCA
  netAmount     Float
  paymentMethod PaymentMethod

  userId        String    // Cashier who made the sale
  user          User      @relation(fields: [userId], references: [id])
  
  pumpId        String?
  pump          Pump?     @relation(fields: [pumpId], references: [id])

  shiftId       String?
  shift         Shift?    @relation(fields: [shiftId], references: [id])

  items         SaleItem[]

  // ZATCA specific fields (Phase 2)
  zatcaQrCode   String?   @db.Text
  zatcaHash     String?

  // Accounting Link - A sale maps exactly to ONE journal entry
  journalEntryId String?  @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  createdAt     DateTime  @default(now())
}

model SaleItem {
  id            String    @id @default(cuid())
  saleId        String
  sale          Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  fuelTypeId    String
  fuelType      FuelType  @relation(fields: [fuelTypeId], references: [id])

  quantity      Float     // Liters sold
  unitPrice     Float     // Price per liter (VAT-inclusive)
  totalPrice    Float     // quantity × unitPrice (VAT-inclusive)
}

// ==========================================
// Purchases & Suppliers
// ==========================================
model Supplier {
  id            String    @id @default(cuid())
  name          String
  vatNumber     String?
  contactInfo   String?
  purchases     Purchase[]
  createdAt     DateTime  @default(now())
}

model Purchase {
  id            String    @id @default(cuid())
  invoiceNumber String

  supplierId    String
  supplier      Supplier  @relation(fields: [supplierId], references: [id])

  fuelTypeId    String
  fuelType      FuelType  @relation(fields: [fuelTypeId], references: [id])

  quantity      Float     // Liters purchased
  unitPrice     Float
  totalAmount   Float

  // Accounting Link
  journalEntryId String?  @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])

  createdAt     DateTime  @default(now())
}

// ==========================================
// Accounting System (Double-Entry Ledger)
// ==========================================
enum AccountType {
  ASSET       // e.g., Cash, Bank, Inventory
  LIABILITY   // e.g., VAT Payable, Accounts Payable
  EQUITY      // e.g., Retained Earnings
  REVENUE     // e.g., Sales Revenue
  EXPENSE     // e.g., Cost of Goods Sold, Salaries
}

// Chart of Accounts (e.g., "1001 Cash", "4001 Sales")
model Account {
  id            String    @id @default(cuid())
  code          String    @unique // e.g., "1001"
  name          String
  type          AccountType

  transactions  LedgerTransaction[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// A single business event (e.g., "Sale of Fuel")
model JournalEntry {
  id            String    @id @default(cuid())
  description   String
  date          DateTime  @default(now())

  transactions  LedgerTransaction[]

  // One-to-one relations back to source documents
  sale          Sale?
  purchase      Purchase?
}

// Individual Debits and Credits
model LedgerTransaction {
  id              String      @id @default(cuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  accountId       String
  account         Account     @relation(fields: [accountId], references: [id])

  debit           Float       @default(0) // Left side of ledger
  credit          Float       @default(0) // Right side of ledger

  createdAt       DateTime    @default(now())
}

// ==========================================
// System Reset Log
// ==========================================
enum ResetType {
  INVOICES_ONLY
  FINANCIAL_DATA
  FULL_SYSTEM
}

model SystemReset {
  id            String    @id @default(cuid())
  type          ResetType
  performedById String
  reason        String?
  details       String?   @db.Text
  createdAt     DateTime  @default(now())
}

// ==========================================
// Audit & Activity Logs
// ==========================================
model ActivityLog {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  action        String    // e.g., "SALE_PROCESSED", "SYSTEM_RESET"
  details       String?   @db.Text
  createdAt     DateTime  @default(now())
}
